# ============================================
# Notion Task Automation - 环境变量配置
# ============================================

# ============================================
# Notion API 配置（必填）
# ============================================

# Notion Integration Token
# 获取方式：https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# Notion Database ID
# 从数据库页面URL获取
NOTION_DATABASE_ID=your_database_id_here

# ============================================
# 路径配置（跨平台支持）
# ============================================

# OpenClaw 工作区路径
# Linux 默认: $HOME/.openclaw/workspace
# macOS 默认: $HOME/.openclaw/workspace  
# 如需自定义，取消下面注释并修改：
# OPENCLAW_WORKSPACE=/Users/yourname/.openclaw/workspace

# 环境变量文件路径（可选）
# OPENCLAW_ENV_FILE=$HOME/.openclaw/workspace/.env

# 日志文件路径（可选，默认 /tmp/notion-skill.log）
# OPENCLAW_LOG_FILE=/tmp/notion-skill.log

# ============================================
# 通知配置（可选）
# ============================================

# 通知渠道：feishu, email, slack
# NOTIFY_CHANNEL=feishu

# 通知目标（飞书用户ID或邮箱）
# NOTIFY_TARGET=user:your_user_id

# Slack Webhook（如需Slack通知）
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxx

# 邮件通知地址
# NOTIFY_EMAIL=your@email.com

# ============================================
# 可选配置
# ============================================

# 日志级别：DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# 最大重试次数
MAX_RETRY=3

# 重试间隔（秒）
RETRY_DELAY=5

# 检查间隔（秒，默认300=5分钟）
# CHECK_INTERVAL=300
